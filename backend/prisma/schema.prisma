// Stellar Tipz — Prisma schema
//
// This is the STARTER schema. Most models are added/extended by individual issues
// (see the "data model" issues). Run `npm run prisma:migrate` after changing this file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A creator/user identified by their Stellar wallet address.
/// Extended by credit, tips and other modules in later issues.
model User {
  id             String   @id @default(cuid())
  stellarAddress String   @unique
  username       String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  profile              Profile?
  leaderboardSnapshots LeaderboardSnapshot[]
  streak               Streak?
  notifications        Notification[]
  webhookSubscriptions WebhookSubscription[]
}

/// Creator's public-facing profile page.
/// Display content lives here; on-chain stats (credit_score, tips_received, etc.)
/// belong on a separate stats/metrics model added in a later issue.
model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  displayName  String?
  avatarUrl    String?
  bio          String?
  website      String?
  xHandle      String?
  bannerUrl    String?
  githubHandle String?
  themeKey     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// API key for service/admin access. Full fields (hashed key, scopes, createdBy) land in #818.
model ApiKey {
  id                   String                @id @default(cuid())
  webhookSubscriptions WebhookSubscription[]
}

/// Outbound webhook subscription for delivering platform events to external URLs.
model WebhookSubscription {
  id        String   @id @default(cuid())
  url       String
  events    String[]
  secret    String
  active    Boolean  @default(true)

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  apiKeyId  String?
  apiKey    ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([apiKeyId])
  @@index([active])
}

/// On-chain tip mirrored off-chain by the indexer.
/// Fields and relations are expanded in the tips/indexer issues.
model Tip {
  id            String   @id @default(cuid())
  txHash        String   @unique
  ledger        Int
  fromAddress   String
  toAddress     String
  amountStroops BigInt
  message       String?
  createdAt     DateTime @default(now())
  refund        Refund?
}

/// Tracks indexer progress per event topic so it can resume after a restart.
model IndexerCursor {
  topic      String   @id
  lastLedger Int
  updatedAt  DateTime @updatedAt
}

/// Refund requests tied to a specific tip.
model Refund {
  id        String   @id @default(cuid())
  tipId     String   @unique
  tip       Tip      @relation(fields: [tipId], references: [id])
  amount    BigInt
  reason    String
  status    String   @default("pending")
  txHash    String?
  createdAt DateTime @default(now())
}

/// In-app notification for a user.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

/// Cached X (Twitter) account metrics.
model XAccount {
  id         String   @id @default(cuid())
  handle     String   @unique
  followers  Int      @default(0)
  engagement Float?
  fetchedAt  DateTime @default(now())
}

/// Leaderboard period tracked by snapshots.
enum Period {
  WEEKLY
  MONTHLY
  ALL_TIME
}

/// Periodic leaderboard snapshot entry for fast reads and historical ranking.
model LeaderboardSnapshot {
  id        String   @id @default(cuid())
  period    Period
  rank      Int
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  totalTips BigInt
  createdAt DateTime @default(now())
}

/// Per-user tipping streak tracking. One row per user (userId is unique).
model Streak {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastTipDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/// Short-lived wallet authentication challenge.
/// Created when a wallet requests a sign-in nonce; deleted (or expired) after verification.
/// TTL is enforced by the application layer via AUTH_CHALLENGE_TTL_SECONDS.
model AuthChallenge {
  id        String   @id @default(cuid())
  /// The wallet address this challenge was issued for.
  address   String
  /// Random nonce the wallet must sign to prove ownership.
  nonce     String   @unique
  /// UTC timestamp after which the challenge is no longer valid.
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([address])
  @@index([expiresAt])
}
